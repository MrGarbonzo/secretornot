# ── Server ───────────────────────────────────────────────────────────────
ROUTER_PORT=8000

# ── Private destination (Secret AI / TEE endpoint) ──────────────────────
SECRET_AI_ENDPOINT=https://secretai-rytn.scrtlabs.com:21434
SECRET_AI_API_KEY=your-secret-ai-api-key

# ── Public destination (OpenAI, etc.) ───────────────────────────────────
PUBLIC_LLM_ENDPOINT=https://api.openai.com
PUBLIC_LLM_API_KEY=sk-your-openai-key

# ── Classifier (Layer 2) — Gemma POC via Secret AI ─────────────────────
# Defaults to SECRET_AI_ENDPOINT / SECRET_AI_API_KEY if not set
CLASSIFIER_ENDPOINT=https://secretai-rytn.scrtlabs.com:21434
CLASSIFIER_API_KEY=your-secret-ai-api-key
CLASSIFIER_MODEL=gemma3:4b

# ── Classifier backend ────────────────────────────────────────────────
# "gemma" (POC — calls Secret AI endpoint) or "distilbert" (production — local ONNX)
CLASSIFIER_BACKEND=gemma
# Path to ONNX model file or directory containing model.onnx (distilbert backend only)
DISTILBERT_MODEL_PATH=training/model.onnx

# ── Classification tuning ──────────────────────────────────────────────
CLASSIFICATION_TIMEOUT_MS=2000
CONFIDENCE_THRESHOLD=0.85
DEFAULT_POLICY=private

# ── Proxy ──────────────────────────────────────────────────────────────
PROXY_TIMEOUT_S=120

# ── Audit ──────────────────────────────────────────────────────────────
AUDIT_LOG_FILE=audit.jsonl
